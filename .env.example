# Chronos Staging Environment Variables

# Backend API Configuration
CHRONOS_API_HOST=localhost
CHRONOS_API_PORT=7899

# Environment (development/staging/production)
CHRONOS_ENV=staging

# Telemetry and Trace Settings
TELEMETRY_LEVEL=verbose
ENABLE_EXTERNAL_OBSERVABILITY=true
ENABLE_EXTERNAL_OBSERVABILITY_VERBOSE=true

# Optional Webhook for Critical Alerting
OBSERVABILITY_WEBHOOK_URL=
