{
  "manifest_version": 3,
  "name": "Chronos Pilot Telemetry",
  "version": "1.0.0",
  "description": "Browser Telemetry and Research Session tracker for Chronos Pilot",
  "permissions": [
    "tabs",
    "activeTab",
    "webNavigation",
    "scripting"
  ],
  "host_permissions": [
    "http://*/*",
    "https://*/*"
  ],
  "background": {
    "service_worker": "background.js"
  }
}
